# ==========================================
# CODE-SENSEI AI ENGINE CONFIGURATION
# ==========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# 1. API KEY (Required)
# Get your free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 2. MODEL NAME (Optional)
# Default: qwen/qwen3-coder:free (free tier, no billing needed)
AI_MODEL_NAME=qwen/qwen3-coder:free

# 3. SITE URL & NAME (Optional)
# Used for OpenRouter analytics
SITE_URL=http://localhost:3000
SITE_NAME=CODE-SENSEI
